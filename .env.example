# Copy to .env.local for development. For Vercel, set these in the dashboard — see VERCEL.md
#
# Resend (booking emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TO_EMAIL=

# Optional: client update automation emails
CLIENT_UPDATE_FROM_EMAIL=
CLIENT_UPDATE_TO_EMAIL=

# Optional: client update automation text messages (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
CLIENT_UPDATE_TO_PHONE=

# Admin dashboard (NextAuth)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
ADMIN_USER=your-admin-username
ADMIN_PASSWORD=use-a-long-random-password

# Optional: Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: store booking leads in Neon (Vercel → Storage → Neon)
# After creating DB, run scripts/booking-leads.sql in the Neon SQL editor.
DATABASE_URL=

# Preview deployments only (Vercel Hobby)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Cloudflare Turnstile (booking form) — set both in Vercel Production
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
